<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FourthFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="0dp"
        android:background="#fff"
        android:orientation="vertical">

        <ImageView
            android:layout_width="220dp"
            android:layout_height="80dp"
            android:background="@drawable/quickchat2"
            android:layout_margin="0dp"
            android:paddingTop="0dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/box_shadow"/>



        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center">

            <!-- Profile Picture -->
            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="12dp"
                android:background="@drawable/profile_picture"
                android:scaleType="centerCrop"
                android:src="@drawable/profile_placeholder" />

            <!-- Upload Button (attached to circle) -->
            <ImageButton
                android:id="@+id/btnUpload"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/btn_upload"
                android:contentDescription="Upload"
                android:padding="8dp"
                android:src="@drawable/camera" />

        </FrameLayout>

        <TextView
            android:id="@+id/txtUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="0dp"

            android:textSize="20sp"
            android:textStyle="bold|normal"
            android:textColor="#181818"
            android:fontFamily="sans-serif"
            />


        <!-- SETTINGS GROUP BACKGROUND -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/menu_bg"
            android:orientation="vertical"

            >


            <!-- ACCOUNT -->
            <LinearLayout
                android:id="@+id/rowAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp" >


                <ImageView
                    android:layout_width="61dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/acc1" />

                <Button
                    android:id="@+id/btnAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:background="@android:color/transparent"
                    android:text="Account"
                    android:textStyle="bold|normal"
                    android:textColor="#181818"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif"
                    />


            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_gravity="bottom"
                android:layout_marginLeft="50dp"/>


            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_gravity="bottom"
                android:layout_marginLeft="50dp"/>


            <!-- CHATS -->
            <LinearLayout
                android:id="@+id/rowChats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/msg1" />

                <Button
                    android:id="@+id/btnChats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:background="@android:color/transparent"
                    android:text="Chats"
                    android:textStyle="bold|normal"
                    android:textColor="#181818"

                    android:textSize="17sp"
                    android:fontFamily="sans-serif"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rowActiveStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <ImageView
                    android:layout_width="61dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/active3"

                    />

                <Button
                    android:id="@+id/btnActiveStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:background="@android:color/transparent"
                    android:text="Active Status"
                    android:textStyle="bold|normal"
                    android:textColor="#181818"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif"
                    />

            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_gravity="bottom"
                android:layout_marginLeft="50dp"/>



            <!-- NOTIFICATIONS -->
            <LinearLayout
                android:id="@+id/rowNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <ImageView
                    android:layout_width="61dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/notification1" />

                <Button
                    android:id="@+id/btnNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:background="@android:color/transparent"
                    android:text="Notifications"
                    android:textStyle="bold|normal"
                    android:textColor="#181818"

                    android:textSize="17sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_gravity="bottom"
                android:layout_marginLeft="50dp"/>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/menu_bg"
            android:orientation="vertical">




            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_gravity="bottom"
                android:layout_marginLeft="50dp"/>



            <!-- PRIVACY -->
            <LinearLayout
                android:id="@+id/rowPrivacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp"
                >

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/privacy4"/>

                <Button
                    android:id="@+id/btnPrivacy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:background="@android:color/transparent"
                    android:text="Privacy"
                    android:textStyle="bold|normal"
                    android:textColor="#181818"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif"
                    />
            </LinearLayout>



            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_gravity="bottom"
                android:layout_marginLeft="50dp"/>

            <LinearLayout
                android:id="@+id/rowSetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <ImageView
                    android:layout_width="61dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/setting1" />

                <Button
                    android:id="@+id/txtSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:background="@android:color/transparent"
                    android:text="Settings"
                    android:textStyle="bold|normal"
                    android:textColor="#181818"

                    android:textSize="17sp"
                    android:fontFamily="sans-serif" />


            </LinearLayout>

            <!-- HELP -->

            <LinearLayout
                android:id="@+id/rowHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <ImageView
                    android:layout_width="61dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/help8"
                     />

                <Button
                    android:id="@+id/btnHelp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:background="@android:color/transparent"
                    android:text="Help"
                    android:textStyle="bold|normal"
                    android:textColor="#181818"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif"

                    />

            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_gravity="bottom"
                android:layout_marginLeft="50dp"/>
            <LinearLayout
                android:id="@+id/rowbtnlogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <ImageView
                    android:layout_width="61dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/exit"
                    />

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:background="@android:color/transparent"
                    android:text="LogOut"
                    android:textStyle="bold|normal"
                    android:textColor="#181818"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif"
                    />



            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_gravity="bottom"
                android:layout_marginLeft="50dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/bg_receiver" />
    </LinearLayout>
</FrameLayout>
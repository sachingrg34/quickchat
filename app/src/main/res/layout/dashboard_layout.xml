<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:backgroundTint="#FFFFFF">


    <!-- Main content area (Fragment will load here) -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:elevation="1dp"/>  <!--bottom straight line -->

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:background="#FFFFFF">
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/FirstFragment"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:text="chats"
            android:textColor="#000"
            android:layout_margin="10dp"
            android:background="@drawable/chatselector"
        />



        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/SecondFragment"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:text="Friends"

            android:textColor="#000"
            android:layout_margin="10dp"
            android:background="@drawable/friendselector" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/ThirdFragment"
            android:layout_width="0dp"
            android:layout_height="70dp"

            android:layout_weight="1"

            android:textColor="#000"
            android:layout_margin="10dp"
            android:background="@drawable/call_selector" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/FourthFragment"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:text="Menu"
            android:textColor="#000000"
            android:layout_margin="10dp"
            android:background="@drawable/menuselector" />

    </LinearLayout>


</LinearLayout>
